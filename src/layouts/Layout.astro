					</h2>
					<p class="text-gray-500 text-sm mb-5">
						Le premier réseau d'entraide autour de l'incontinence à Toulon et dans le Var.
					</p>
					<p class="text-gray-600 text-sm leading-relaxed mb-8">
						Que vous soyez un <strong>patient</strong> en quête de solutions, une <strong>infirmière</strong> dévouée, une <strong>association partenaire</strong> ou un <strong>professionnel du matériel médical</strong>, ce réseau est le vôtre. Ensemble, nous faisons reculer les tabous chaque jour.
					</p>
					<button id="welcome-enter" class="w-full bg-teal-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-teal-700 transition-colors text-sm">
						Découvrir le site
					</button>
					<a href={`${base}rejoindre-association-toulon-83000/`} class="inline-block mt-4 text-teal-600 hover:text-teal-800 text-xs font-medium transition-colors" id="welcome-join">
						Rejoindre l'association &rarr;
					</a>
				</div>
			</div>
		</div>

		<script>
			const toggle = document.getElementById('menu-toggle');
			const menu = document.getElementById('mobile-menu');
			toggle?.addEventListener('click', () => {
				menu?.classList.toggle('hidden');
			});
			menu?.querySelectorAll('a').forEach(link => {
				link.addEventListener('click', () => {
					menu?.classList.add('hidden');
				});
			});

			// Back to top button
			const backToTop = document.getElementById('back-to-top');
			window.addEventListener('scroll', () => {
				if (window.scrollY > 400) {
					backToTop?.classList.remove('opacity-0', 'invisible');
					backToTop?.classList.add('opacity-100', 'visible');
				} else {
					backToTop?.classList.add('opacity-0', 'invisible');
					backToTop?.classList.remove('opacity-100', 'visible');
				}
			});
			backToTop?.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			// Popup de bienvenue (une seule fois, expire après 30 jours)
			const overlay = document.getElementById('welcome-overlay');
			const modal = document.getElementById('welcome-modal');
			const STORAGE_KEY = 'vi_popup_seen';
			const EXPIRY_DAYS = 30;

			function shouldShowPopup() {
				const stored = localStorage.getItem(STORAGE_KEY);
				if (!stored) return true;
				const timestamp = parseInt(stored, 10);
				const elapsed = Date.now() - timestamp;
				return elapsed > EXPIRY_DAYS * 24 * 60 * 60 * 1000;
			}

			function showPopup() {
				if (!overlay || !modal) return;
				overlay.classList.remove('invisible', 'opacity-0');
				overlay.classList.add('opacity-100');
				modal.classList.remove('scale-95', 'opacity-0');
				modal.classList.add('scale-100', 'opacity-100');
				document.body.style.overflow = 'hidden';
			}

			function closePopup() {
				if (!overlay || !modal) return;
				modal.classList.add('scale-95', 'opacity-0');
				modal.classList.remove('scale-100', 'opacity-100');
				overlay.classList.add('opacity-0');
				setTimeout(() => {
					overlay.classList.add('invisible');
					document.body.style.overflow = '';
				}, 300);
				localStorage.setItem(STORAGE_KEY, Date.now().toString());
			}

			if (shouldShowPopup()) {
				setTimeout(showPopup, 800);
			} else if (overlay) {
				overlay.remove();
			}

			document.getElementById('welcome-close')?.addEventListener('click', closePopup);
			document.getElementById('welcome-enter')?.addEventListener('click', closePopup);
			document.getElementById('welcome-join')?.addEventListener('click', () => {
				localStorage.setItem(STORAGE_KEY, Date.now().toString());
			});

			overlay?.addEventListener('click', (e) => {
				if (e.target === overlay) closePopup();
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && overlay && !overlay.classList.contains('invisible')) {
					closePopup();
				}
			});

			// Sticker preuve sociale (bas gauche)
			const spEl = document.getElementById('social-proof');
			const spIcon = document.getElementById('sp-icon');
			const spText = document.getElementById('sp-text');

			const spMessages = [
				{ icon: '\uD83D\uDC65', tpl: (n) => `<strong class="text-teal-700">${n} personnes</strong> de la région toulonnaise consultent l'annuaire des infirmières.` },
				{ icon: '\uD83D\uDC65', tpl: (n) => `<strong class="text-teal-700">${n} visiteurs</strong> s'informent sur les solutions contre l'incontinence.` },
				{ icon: '\uD83E\uDD1D', tpl: (n) => `<strong class="text-teal-700">${n} professionnels de santé</strong> parcourent notre annuaire en ce moment.` },
				{ icon: '\uD83D\uDC41\uFE0F', tpl: (n) => `<strong class="text-teal-700">${n} membres</strong> consultent la page Matériel médical à Toulon.` },
				{ icon: '\uD83D\uDC65', tpl: (n) => `<strong class="text-teal-700">${n} Varois</strong> lisent nos conseils de prévention aujourd'hui.` },
				{ icon: '\uD83D\uDC41\uFE0F', tpl: (n) => `<strong class="text-teal-700">${n} personnes</strong> consultent le forum d'entraide en ce moment.` },
				{ icon: '\uD83E\uDD1D', tpl: (n) => `<strong class="text-teal-700">${n} associations</strong> partenaires sont actives sur le réseau ce mois-ci.` },
				{ icon: '\uD83D\uDC65', tpl: (n) => `<strong class="text-teal-700">${n} aidants</strong> trouvent du soutien sur notre plateforme cette semaine.` },
				{ icon: '\uD83D\uDC41\uFE0F', tpl: (n) => `<strong class="text-teal-700">${n} personnes</strong> recherchent du matériel médical dans le Var.` },
				{ icon: '\uD83E\uDD1D', tpl: (n) => `<strong class="text-teal-700">${n} nouveaux membres</strong> ont rejoint l'association ce mois-ci.` }
			];

			function getVisitorCount() {
				const hour = new Date().getHours();
				let base = 12, range = 15;
				if (hour >= 8 && hour <= 12) { base = 18; range = 17; }
				else if (hour >= 14 && hour <= 19) { base = 15; range = 15; }
				else if (hour >= 20 || hour < 7) { base = 5; range = 8; }
				return base + Math.floor(Math.random() * range);
			}

			let spIndex = Math.floor(Math.random() * spMessages.length);

			function showSocialProof() {
				if (!spEl || !spIcon || !spText) return;
				const msg = spMessages[spIndex];
				spIcon.textContent = msg.icon;
				spText.innerHTML = msg.tpl(getVisitorCount());
				spEl.classList.remove('opacity-0', 'invisible', 'translate-y-2');
				spEl.classList.add('opacity-100', 'visible', 'translate-y-0');
				spIndex = (spIndex + 1) % spMessages.length;

				setTimeout(() => {
					spEl.classList.add('opacity-0', 'translate-y-2');
					spEl.classList.remove('opacity-100', 'translate-y-0');
					setTimeout(() => {
						spEl.classList.add('invisible');
						const next = 7000 + Math.floor(Math.random() * 28000);
						setTimeout(showSocialProof, next);
					}, 500);
				}, 5500);
			}

			setTimeout(showSocialProof, 15000);
		</script>
		<SpeedInsights />
		<Analytics />
	</body>
</html>
