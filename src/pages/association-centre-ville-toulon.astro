---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const associations = [
	{
		nom: "Maison des Associations de Toulon",
		description: "Structure municipale fédérant la vie associative toulonnaise. Accueil, orientation, mise à disposition de salles et accompagnement administratif pour les associations du centre-ville et de toute la commune.",
		adresse: "Place Noël Blache, 83000 Toulon",
		domaines: ["Vie associative", "Accompagnement", "Ressources"]
	},
	{
		nom: "Secours Populaire Français - Comité de Toulon",
		description: "Aide alimentaire, vestimentaire et accès aux droits pour les personnes en situation de précarité. Permanences d'accueil au centre-ville, distribution de colis alimentaires et accompagnement social.",
		adresse: "15 rue Vincent Courdouan, 83000 Toulon",
		domaines: ["Solidarité", "Aide alimentaire", "Accès aux droits"]
	},
	{
		nom: "Toulon Centre Culture",
		description: "Promotion de la vie culturelle au centre-ville de Toulon. Organisation d'expositions, concerts, lectures publiques et ateliers artistiques dans les salles municipales et espaces associatifs.",
		adresse: "8 rue des Arts, 83000 Toulon",
		domaines: ["Culture", "Art", "Événements"]
	},
	{
		nom: "Association d'Aide aux Personnes Isolées du Var",
		description: "Lutte contre l'isolement social des personnes vulnérables du centre-ville. Maraudes, visites à domicile, accompagnement vers les structures de soins et d'hébergement, écoute téléphonique.",
		adresse: "22 cours Lafayette, 83000 Toulon",
		domaines: ["Solidarité", "Isolement", "Accompagnement social"]
	},
	{
		nom: "Santé Solidarité Centre-Ville",
		description: "Accès aux soins pour les publics précaires du centre-ville. Consultations médicales gratuites, aide à l'ouverture des droits (CSS, AME), orientation vers les spécialistes et prévention santé.",
		adresse: "31 rue Jean Jaurès, 83000 Toulon",
		domaines: ["Santé", "Solidarité", "Accès aux soins"]
	},
	{
		nom: "Comité de Quartier Centre-Ville Toulon",
		description: "Représentation des habitants du centre-ville auprès de la municipalité. Cadre de vie, propreté, sécurité, circulation : le comité défend les intérêts des résidents et organise des événements de quartier.",
		adresse: "Place de la Liberté, 83000 Toulon",
		domaines: ["Vie de quartier", "Citoyenneté", "Cadre de vie"]
	},
	{
		nom: "Les Restos du Cœur - Antenne Toulon Centre",
		description: "Distribution de repas et aide alimentaire aux personnes démunies. Permanences d'accueil, ateliers d'insertion sociale et accompagnement vers l'emploi et le logement au centre-ville de Toulon.",
		adresse: "45 avenue du Général Leclerc, 83000 Toulon",
		domaines: ["Aide alimentaire", "Insertion", "Solidarité"]
	},
	{
		nom: "Sport pour Tous Centre Toulon",
		description: "Activités sportives accessibles à tous les publics : seniors, personnes en situation de handicap, familles modestes. Cours de gym douce, yoga, marche urbaine et activités en plein air sur les places du centre-ville.",
		adresse: "10 rue Anatole France, 83000 Toulon",
		domaines: ["Sport adapté", "Inclusion", "Bien-être"]
	}
];
---

<Layout title="Associations Centre-Ville Toulon (83) — Annuaire Complet">

	<meta slot="head" name="description" content="Découvrez les associations du centre-ville de Toulon. Solidarité, santé, culture : annuaire avec adresses et contacts." />

	<script slot="head" type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "ItemList",
		"name": "Associations du centre-ville de Toulon",
		"description": "Liste des associations du centre-ville de Toulon (83)",
		"numberOfItems": associations.length,
		"itemListElement": associations.map((a, i) => ({
			"@type": "ListItem",
			"position": i + 1,
			"item": {
				"@type": "Organization",
				"name": a.nom,
				"description": a.description,
				"address": { "@type": "PostalAddress", "streetAddress": a.adresse, "addressLocality": "Toulon", "postalCode": "83000" }
			}
		}))
	})} />

	<!-- Hero -->
	<section class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white py-16 md:py-20">
		<div class="max-w-6xl mx-auto px-4">
			<nav class="text-teal-200 text-sm mb-6" aria-label="Fil d'Ariane">
				<a href={base} class="hover:text-white transition-colors">Accueil</a>
				<span class="mx-2">/</span>
				<a href={`${base}toulon-association/`} class="hover:text-white transition-colors">Associations à Toulon</a>
				<span class="mx-2">/</span>
				<span class="text-white">Centre-Ville</span>
			</nav>
			<h1 class="text-3xl md:text-5xl font-bold mb-4">Associations du centre-ville de Toulon</h1>
			<p class="text-lg text-teal-100 max-w-3xl">
				Annuaire complet des associations actives dans le centre-ville de Toulon (83). Solidarité, santé, culture, sport et vie de quartier : toutes les structures près de la Place de la Liberté et du cours Lafayette.
			</p>
			<div class="mt-6 flex items-center gap-2 text-teal-200 text-sm">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
				<span>{associations.length} associations référencées au centre-ville</span>
			</div>
		</div>
	</section>

	<!-- Introduction SEO -->
	<section class="py-12 bg-gray-50 border-b border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Centre-ville de Toulon : le cœur de la vie associative</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					Le centre-ville de Toulon concentre la plus forte densité associative de la commune. Autour de la <strong>Place de la Liberté</strong>, du <strong>cours Lafayette</strong> et de la <strong>rue des Arts</strong>, de nombreuses associations ont installé leurs permanences pour être au plus près des habitants et des publics qu'elles accompagnent. La <strong>Maison des Associations</strong>, située place Noël Blache, fédère cette vie associative en offrant salles, ressources et accompagnement.
				</p>
				<p>
					Le centre-ville de Toulon se caractérise par une grande diversité sociale. Quartier commerçant et administratif, il abrite à la fois des résidents anciens, des étudiants, des familles et des personnes en situation de précarité. Cette mixité se reflète dans la variété des <strong>associations du centre-ville</strong> : structures de solidarité et d'aide alimentaire côtoient des associations culturelles, sportives et de défense du cadre de vie.
				</p>
				<p>
					Le centre-ville est également classé en partie <strong>quartier prioritaire de la politique de la ville</strong>, ce qui renforce les besoins en accompagnement social et en accès aux soins. Les associations jouent ici un rôle de premier plan pour orienter les habitants vers les dispositifs d'aide existants : CSS (Complémentaire Santé Solidaire), aides au logement, insertion professionnelle et accès aux droits.
				</p>
				<p>
					Pour découvrir l'ensemble des associations toulonnaises, consultez notre <a href={`${base}toulon-association/`} class="text-teal-600 underline hover:text-teal-800">annuaire complet des associations à Toulon</a>. Notre page <a href={`${base}quartiers-toulon-incontinence/`} class="text-teal-600 underline hover:text-teal-800">aide par quartier</a> propose des ressources santé adaptées à chaque secteur de la ville.
				</p>
			</div>
		</div>
	</section>

	<!-- Liste des associations -->
	<section class="py-16 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-8">Les associations du centre-ville de Toulon</h2>
			<div class="grid gap-5">
				{associations.map((a, i) => (
					<article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:border-teal-300 hover:shadow-md transition-all">
						<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-3">
									<span class="w-8 h-8 bg-teal-100 text-teal-700 rounded-lg flex items-center justify-center text-sm font-bold">{i + 1}</span>
									<h3 class="text-xl font-bold text-gray-900">{a.nom}</h3>
								</div>
								<p class="text-gray-600 mb-4">{a.description}</p>
								<div class="flex flex-wrap gap-2">
									{a.domaines.map(d => (
										<span class="bg-teal-50 text-teal-700 text-xs font-medium px-3 py-1 rounded-full">{d}</span>
									))}
								</div>
							</div>
							<div class="md:text-right shrink-0 space-y-2">
								<div class="flex items-center gap-2 text-sm text-gray-600">
									<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
									<span>{a.adresse}</span>
								</div>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Caractéristiques du quartier -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Centre-ville de Toulon : caractéristiques et lieux clés</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<h3 class="text-xl font-bold text-gray-900">Un quartier historique et commerçant</h3>
				<p>
					Le centre-ville de Toulon s'articule autour de plusieurs pôles emblématiques. La Place de la Liberté, l'une des plus grandes places de France, constitue le cœur administratif et culturel de la ville. L'Opéra de Toulon, le musée d'art et les cinémas attirent une vie culturelle riche. Le cours Lafayette accueille chaque matin un marché provençal réputé, tandis que la vieille ville offre un dédale de ruelles commerçantes entre la cathédrale Sainte-Marie et le port.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Accès aux soins et services sociaux</h3>
				<p>
					Le centre-ville concentre de nombreux cabinets médicaux, pharmacies et laboratoires d'analyses. La proximité du CHITS Sainte-Musse et de la Clinique Saint-Martin offre un accès rapide aux soins hospitaliers. Le CCAS de Toulon, situé au centre-ville, propose des permanences sociales pour l'accès aux droits, l'aide aux personnes âgées et l'accompagnement des publics fragiles. Plusieurs associations de santé complètent ce dispositif avec des consultations gratuites et de la prévention.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Lieux clés du centre-ville</h3>
				<ul class="list-disc pl-6 space-y-2">
					<li><strong>Place de la Liberté</strong> : cœur administratif, fontaine monumentale, terrasses et commerces.</li>
					<li><strong>Cours Lafayette</strong> : marché provençal quotidien, artère commerçante historique.</li>
					<li><strong>Maison des Associations</strong> : lieu ressource pour toutes les associations toulonnaises.</li>
					<li><strong>Rue des Arts</strong> : galeries, ateliers et espaces culturels associatifs.</li>
					<li><strong>Opéra de Toulon</strong> : scène lyrique et spectacles, l'un des plus grands opéras de province.</li>
					<li><strong>Cathédrale Sainte-Marie</strong> : patrimoine historique au cœur de la vieille ville.</li>
					<li><strong>Port de Toulon</strong> : promenade, navettes maritimes et vie portuaire.</li>
				</ul>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Un quartier en renouvellement</h3>
				<p>
					Le centre-ville de Toulon fait l'objet d'un vaste programme de rénovation urbaine visant à améliorer l'habitat, les espaces publics et l'attractivité commerciale. Ces transformations renforcent le rôle des associations dans l'accompagnement des habitants, qu'il s'agisse de médiation sociale, de soutien aux personnes âgées confrontées aux travaux ou d'animation de la vie de quartier pendant les phases de chantier.
				</p>
			</div>
		</div>
	</section>

	<!-- Solidarité et santé -->
	<section class="py-12 bg-white border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Solidarité et santé au centre-ville de Toulon</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					Le centre-ville de Toulon concentre une part importante des publics vulnérables de la commune : personnes sans domicile, familles monoparentales en difficulté, personnes âgées isolées et migrants en attente de régularisation. Les associations de solidarité y sont donc particulièrement actives, avec des permanences quotidiennes d'accueil, d'écoute et d'orientation.
				</p>
				<p>
					L'accès aux soins constitue un enjeu majeur pour ces publics. Les associations santé du centre-ville proposent des consultations médicales gratuites, une aide à l'ouverture des droits à la CSS (ex-CMU) et une orientation vers les dispositifs de prévention. Pour les personnes atteintes de maladies chroniques entraînant une <strong>incontinence</strong>, l'association Var Incontinence offre un accompagnement discret et bienveillant, sans condition de ressources.
				</p>
				<p>
					Consultez notre page d'<a href={`${base}entraide-incontinence-toulon/`} class="text-teal-600 underline hover:text-teal-800">entraide incontinence à Toulon</a> pour découvrir nos groupes de soutien et nos permanences d'information au centre-ville.
				</p>
			</div>
		</div>
	</section>

	<!-- Maillage interne -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-xl font-bold text-gray-900 mb-4">Pages associées</h2>
			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
				<a href={`${base}toulon-association/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Voir toutes les associations à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Annuaire complet</p>
				</a>
				<a href={`${base}quartiers-toulon-incontinence/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Aide par quartier à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Ressources locales</p>
				</a>
				<a href={`${base}maison-associations-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Maison des Associations</p>
					<p class="text-xs text-gray-500 mt-1">Ressources et salles</p>
				</a>
				<a href={`${base}association-sante-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Associations santé Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Maladies et prévention</p>
				</a>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-16 bg-teal-50">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-2xl font-bold text-gray-900 mb-4">Besoin d'aide au centre-ville de Toulon ?</h2>
			<p class="text-gray-600 mb-8">Var Incontinence vous oriente vers les associations et services de santé du centre-ville adaptés à votre situation.</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href={`${base}#contact`} class="inline-block bg-teal-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-teal-700 transition-colors">Contactez-nous</a>
				<a href={`${base}rejoindre-association-toulon-83000/`} class="inline-block border-2 border-teal-600 text-teal-700 font-semibold px-8 py-3 rounded-full hover:bg-teal-50 transition-colors">Rejoindre l'association</a>
			</div>
		</div>
	</section>

</Layout>
