</tr>
</thead>
<tbody>
<tr>
<td class="border border-gray-300 px-4 py-2">Accueil de l'enfant</td>
<td class="border border-gray-300 px-4 py-2">Évaluation des besoins, dialogue avec les parents</td>
<td class="border border-gray-300 px-4 py-2">Directrice, référent</td>
<td class="border border-gray-300 px-4 py-2">Fiche d'accueil adaptée</td>
</tr>
<tr>
<td class="border border-gray-300 px-4 py-2">Adaptation progressive</td>
<td class="border border-gray-300 px-4 py-2">Mise en place de routines spécifiques</td>
<td class="border border-gray-300 px-4 py-2">Équipe éducative</td>
<td class="border border-gray-300 px-4 py-2">Planning personnalisé</td>
</tr>
<tr>
<td class="border border-gray-300 px-4 py-2">Gestion des incidents</td>
<td class="border border-gray-300 px-4 py-2">Change discret, nettoyage, réconfort</td>
<td class="border border-gray-300 px-4 py-2">Auxiliaire formée</td>
<td class="border border-gray-300 px-4 py-2">Kit de change complet</td>
</tr>
<tr>
<td class="border border-gray-300 px-4 py-2">Suivi quotidien</td>
<td class="border border-gray-300 px-4 py-2">Observation, communication parents</td>
<td class="border border-gray-300 px-4 py-2">Tous les professionnels</td>
<td class="border border-gray-300 px-4 py-2">Cahier de liaison</td>
</tr>
</tbody>
</table>
