<Layout
	title="Incontinence et accès à la mer : profiter des plages de Toulon et du Var en toute sérénité | Var Incontinence"
	description="Guide complet pour profiter des plages de Toulon avec une incontinence : équipements, conseils pratiques et lieux adaptés dans le Var."
>

	<!-- Hero -->
	<section class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white py-16 md:py-20">
		<div class="max-w-4xl mx-auto px-4">
