</tr>
<tr>
<td class="border border-gray-300 px-4 py-2">18h-22h</td>
<td class="border border-gray-300 px-4 py-2">300-400ml</td>
<td class="border border-gray-300 px-4 py-2">Eau, tisanes rafraîchissantes</td>
<td class="border border-gray-300 px-4 py-2">Diminuer progressivement</td>
</tr>
</tbody>
</table>
