				<a href={`${base}rejoindre-association-toulon-83000/`} class="inline-block border-2 border-teal-600 text-teal-600 font-semibold px-8 py-3 rounded-full hover:bg-teal-600 hover:text-white transition-colors">Rejoindre Var Incontinence</a>
