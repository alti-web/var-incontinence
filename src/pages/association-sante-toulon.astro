---
import Layout from '../layouts/Layout.astro';
import { associations } from '../data/associations';
import { toSlug } from '../data/utils';

const base = import.meta.env.BASE_URL;
const santeAssos = associations.filter(a => a.categorie === 'Santé & Maladies chroniques');
---

<Layout title="Associations Santé à Toulon (83) — Maladies et Prévention | Var Incontinence">

	<meta slot="head" name="description" content="Liste des associations santé à Toulon : cancer, diabète, maladies chroniques, prévention. Contacts et accompagnement dans le Var." />

	<script slot="head" type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "ItemList",
		"name": "Associations santé à Toulon",
		"description": "Liste des associations santé et maladies chroniques à Toulon (83)",
		"numberOfItems": santeAssos.length,
		"itemListElement": santeAssos.map((a, i) => ({
			"@type": "ListItem",
			"position": i + 1,
			"item": {
				"@type": "Organization",
				"name": a.nom,
				"description": a.description,
				"address": { "@type": "PostalAddress", "streetAddress": a.adresse, "addressLocality": "Toulon", "postalCode": "83000" },
				...(a.telephone ? { "telephone": a.telephone } : {})
			}
		}))
	})} />

	<!-- Hero -->
	<section class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white py-16 md:py-20">
		<div class="max-w-6xl mx-auto px-4">
			<nav class="text-teal-200 text-sm mb-6" aria-label="Fil d'Ariane">
				<a href={base} class="hover:text-white transition-colors">Accueil</a>
				<span class="mx-2">/</span>
				<a href={`${base}toulon-association/`} class="hover:text-white transition-colors">Associations à Toulon</a>
				<span class="mx-2">/</span>
				<span class="text-white">Santé</span>
			</nav>
			<h1 class="text-3xl md:text-5xl font-bold mb-4">Associations santé à Toulon : prévention et accompagnement</h1>
			<p class="text-lg text-teal-100 max-w-3xl">
				Annuaire complet des associations santé à Toulon et dans le Var (83). Cancer, diabète, maladies cardiovasculaires, maladies chroniques : accompagnement des patients, prévention et soutien aux proches.
			</p>
			<div class="mt-6 flex items-center gap-2 text-teal-200 text-sm">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
				<span>{santeAssos.length} associations référencées</span>
			</div>
		</div>
	</section>

	<!-- Introduction SEO -->
	<section class="py-12 bg-gray-50 border-b border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Associations santé à Toulon : un réseau au service des patients</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					Le département du Var compte plus de <strong>1,1 million d'habitants</strong>, et comme partout en France, les maladies chroniques y représentent un enjeu majeur de santé publique. À Toulon, chef-lieu du département, un tissu associatif dense s'est développé pour accompagner les patients atteints de pathologies variées : cancers, diabète, maladies cardiovasculaires, maladies neurodégénératives ou encore maladies rares.
				</p>
				<p>
					Ces <strong>associations santé à Toulon</strong> remplissent des missions complémentaires au système de soins : <strong>information et prévention</strong> (dépistage, sensibilisation, éducation thérapeutique), <strong>soutien psychologique</strong> (groupes de parole, accompagnement individuel), <strong>aide aux démarches administratives</strong> (droits des patients, ALD, aides financières) et <strong>amélioration de la qualité de vie</strong> (activités physiques adaptées, ateliers bien-être, nutrition).
				</p>
				<p>
					Parmi les problématiques de santé fréquemment associées aux maladies chroniques, l'<strong>incontinence urinaire</strong> touche de nombreux patients, notamment après un traitement contre le cancer de la prostate, en cas de diabète avancé ou à la suite d'un AVC. Notre page d'<a href={`${base}entraide-incontinence-toulon/`} class="text-teal-600 underline hover:text-teal-800">entraide incontinence à Toulon</a> propose un accompagnement dédié à cette problématique souvent taboue.
				</p>
				<p>
					Que vous soyez patient, proche ou professionnel de santé, vous trouverez ci-dessous l'ensemble des associations santé et maladies chroniques actives à Toulon. Pour une vue d'ensemble de toutes les associations du territoire, consultez notre <a href={`${base}toulon-association/`} class="text-teal-600 underline hover:text-teal-800">annuaire complet des associations à Toulon</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- Liste des associations santé -->
	<section class="py-16 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-8">Les associations santé et maladies chroniques à Toulon</h2>
			<div class="grid gap-5">
				{santeAssos.map((a, i) => (
					<article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:border-teal-300 hover:shadow-md transition-all">
						<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-3">
									<span class="w-8 h-8 bg-blue-100 text-blue-700 rounded-lg flex items-center justify-center text-sm font-bold">{i + 1}</span>
									<h3 class="text-xl font-bold text-gray-900">{a.nom}</h3>
								</div>
								<p class="text-gray-600 mb-4">{a.description}</p>
								<div class="flex flex-wrap gap-2">
									{a.domaines.map(d => (
										<span class="bg-blue-50 text-blue-700 text-xs font-medium px-3 py-1 rounded-full">{d}</span>
									))}
								</div>
							</div>
							<div class="md:text-right shrink-0 space-y-2">
								<div class="flex items-center gap-2 text-sm text-gray-600">
									<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
									<span>{a.adresse}</span>
								</div>
								{a.telephone && (
									<div class="flex items-center gap-2 text-sm">
										<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
										<a href={`tel:${a.telephone.replace(/\s/g, '')}`} class="text-teal-600 font-medium hover:text-teal-800">{a.telephone}</a>
									</div>
								)}
								{a.siteWeb && (
									<div class="flex items-center gap-2 text-sm">
										<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
										<a href={a.siteWeb} target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-800 truncate max-w-[200px]">{a.siteWeb.replace('https://', '').replace('www.', '')}</a>
									</div>
								)}
								<div class="mt-2">
									<a href={`${base}association/${toSlug(a.nom)}/`} class="inline-flex items-center gap-1 text-xs text-white bg-teal-600 hover:bg-teal-700 font-medium px-3 py-1.5 rounded-full transition-all">
										<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
										Voir la fiche
									</a>
								</div>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Pathologies par type -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Les associations santé à Toulon par pathologie</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<h3 class="text-xl font-bold text-gray-900">Cancer</h3>
				<p>
					Le cancer reste la première cause de mortalité en France. À Toulon, la <strong>Ligue contre le Cancer - Comité du Var</strong> constitue l'association de référence pour l'accompagnement des malades et de leurs proches. Elle propose un soutien psychologique individuel, des groupes de parole, une aide financière d'urgence et des soins de bien-être (socio-esthétique, sophrologie). L'association mène également des actions de prévention dans les établissements scolaires et les entreprises du Var.
				</p>
				<p>
					Pour les patients atteints de cancer de la prostate, les conséquences urinaires post-opératoires sont fréquentes. Notre association propose un accompagnement spécifique sur cette problématique via notre page d'<a href={`${base}entraide-incontinence-toulon/`} class="text-teal-600 underline hover:text-teal-800">entraide incontinence à Toulon</a>.
				</p>

				<h3 class="text-xl font-bold text-gray-900 pt-4">Diabète</h3>
				<p>
					Le diabète touche environ <strong>5% de la population française</strong>, et le Var n'échappe pas à cette tendance. L'<strong>Association des Diabétiques du Var</strong> organise des réunions mensuelles d'information, des ateliers nutrition encadrés par des diététiciens, des marches santé et des conférences avec des endocrinologues. L'association accompagne aussi les patients dans la défense de leurs droits (ALD, assurance, permis de conduire) et la prévention des complications du diabète.
				</p>

				<h3 class="text-xl font-bold text-gray-900 pt-4">Maladies cardiovasculaires et AVC</h3>
				<p>
					Les maladies cardiovasculaires représentent la deuxième cause de décès en France. À Toulon, l'<strong>Association AVC Var</strong> accompagne les victimes d'accidents vasculaires cérébraux et leurs familles. Elle propose des groupes de parole, des ateliers de rééducation cognitive et des actions de sensibilisation à la prévention des AVC. L'association informe également sur les signes d'alerte et l'importance d'une prise en charge rapide.
				</p>
				<p>
					Après un AVC, de nombreux patients présentent des troubles urinaires. L'incontinence post-AVC nécessite un accompagnement adapté que notre réseau associatif peut fournir conjointement avec les structures de rééducation du Var.
				</p>

				<h3 class="text-xl font-bold text-gray-900 pt-4">Maladies neurodégénératives</h3>
				<p>
					La <strong>maladie d'Alzheimer</strong> et la <strong>maladie de Parkinson</strong> sont deux pathologies neurodégénératives majeures accompagnées à Toulon. <strong>France Alzheimer Var</strong> propose des groupes de parole, des formations pour les aidants familiaux, des cafés mémoire et des activités de stimulation cognitive. <strong>France Parkinson - Comité du Var</strong> organise des conférences médicales, des activités physiques adaptées (gym douce, marche nordique) et des échanges entre patients.
				</p>

				<h3 class="text-xl font-bold text-gray-900 pt-4">Maladies rares et autres pathologies</h3>
				<p>
					Le tissu associatif toulonnais couvre également des pathologies plus spécifiques. L'association <strong>Vaincre la Mucoviscidose</strong> soutient les familles concernées et finance la recherche. <strong>AURA Var</strong> accompagne les patients insuffisants rénaux (dialyse, greffe). <strong>SOS Hépatites PACA</strong> assure des permanences d'information et des actions de dépistage. L'association <strong>Fibromyalgie Var</strong> propose des groupes de parole et des ateliers de gestion de la douleur chronique pour les personnes atteintes de fibromyalgie.
				</p>

				<h3 class="text-xl font-bold text-gray-900 pt-4">Incontinence et troubles urinaires</h3>
				<p>
					L'incontinence urinaire touche des millions de personnes en France et reste pourtant largement taboue. Elle peut survenir dans le cadre de nombreuses pathologies chroniques : diabète, maladies neurologiques, suites de cancer, vieillissement. Notre association <strong>Var Incontinence</strong> propose un accompagnement spécifique avec des groupes d'entraide, une orientation vers les professionnels de santé spécialisés et des informations sur les protections et traitements disponibles. Consultez notre page dédiée à l'<a href={`${base}entraide-incontinence-toulon/`} class="text-teal-600 underline hover:text-teal-800">association incontinence à Toulon</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- Prévention et dépistage -->
	<section class="py-12 bg-white border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Prévention et dépistage santé à Toulon</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					La prévention est un pilier fondamental de la politique de santé dans le Var. Les associations santé de Toulon jouent un rôle actif dans les campagnes de <strong>dépistage et de sensibilisation</strong> tout au long de l'année. Octobre Rose (cancer du sein), Movember (cancer de la prostate), la Journée mondiale du diabète en novembre ou encore la Semaine du cerveau en mars sont autant d'occasions de mobiliser le public.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Les dispositifs de prévention dans le Var</h3>
				<ul class="list-disc pl-6 space-y-2">
					<li><strong>Centre Régional de Coordination des Dépistages des Cancers (CRCDC PACA)</strong> : dépistages organisés du cancer du sein (mammographie gratuite dès 50 ans), du cancer colorectal et du cancer du col de l'utérus.</li>
					<li><strong>Centre de dépistage anonyme et gratuit (CeGIDD)</strong> : dépistage du VIH, des hépatites et des IST au centre hospitalier de Toulon.</li>
					<li><strong>Bilan de santé gratuit de la CPAM</strong> : examen de prévention santé complet, accessible tous les 5 ans pour les assurés sociaux du Var.</li>
					<li><strong>Vaccination et prévention</strong> : les centres de vaccination du Var proposent des consultations gratuites pour la mise à jour du calendrier vaccinal.</li>
					<li><strong>Ateliers de prévention associatifs</strong> : les associations santé organisent régulièrement des conférences, des marches santé et des ateliers nutrition ouverts à tous dans le Var.</li>
				</ul>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Droits des patients et ALD dans le Var</h3>
				<p>
					Les personnes atteintes de <strong>maladies chroniques</strong> peuvent bénéficier du dispositif d'<strong>Affection de Longue Durée (ALD)</strong>, qui permet une prise en charge à 100% par l'Assurance Maladie des soins liés à leur pathologie. Parmi les 30 ALD reconnues figurent le diabète, les cancers, les maladies cardiovasculaires, la sclérose en plaques, la maladie de Parkinson et la mucoviscidose. Les associations listées sur cette page peuvent vous aider dans vos démarches auprès de la CPAM du Var.
				</p>
				<p>
					Pour les personnes dont la maladie chronique entraîne un handicap, la <strong>MDPH du Var</strong> peut également intervenir pour la reconnaissance d'un taux d'incapacité et l'accès aux droits associés. Consultez notre page dédiée aux <a href={`${base}association-handicap-toulon/`} class="text-teal-600 underline hover:text-teal-800">associations handicap à Toulon</a> pour plus d'informations.
				</p>
			</div>
		</div>
	</section>

	<!-- Accompagnement des proches -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Soutien aux proches et aidants de malades chroniques</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					Accompagner un proche atteint d'une maladie chronique ou grave est une épreuve qui impacte profondément la vie quotidienne. Les <strong>aidants familiaux</strong> sont souvent confrontés à l'épuisement physique et psychologique, à l'isolement social et à des difficultés financières. À Toulon, plusieurs associations proposent un soutien spécifique aux aidants de personnes malades.
				</p>
				<p>
					<strong>France Alzheimer Var</strong> organise des formations de 14 heures pour les aidants familiaux, abordant la compréhension de la maladie, la communication avec le malade et la gestion du stress. La <strong>Ligue contre le Cancer</strong> propose des entretiens individuels pour les proches de patients en traitement. <strong>France Parkinson</strong> anime des groupes de parole réunissant patients et aidants.
				</p>
				<p>
					Pour un accompagnement plus global des aidants, quelle que soit la pathologie de leur proche, consultez notre page dédiée aux <a href={`${base}association-aidants-toulon/`} class="text-teal-600 underline hover:text-teal-800">associations de soutien aux aidants à Toulon</a>. Vous y trouverez des structures proposant du répit, des groupes de parole et un accompagnement dans les démarches administratives.
				</p>
			</div>
		</div>
	</section>

	<!-- Maillage interne -->
	<section class="py-12 bg-white border-t border-gray-100">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-xl font-bold text-gray-900 mb-4">Pages associées</h2>
			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
				<a href={`${base}toulon-association/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Annuaire complet des associations à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Toutes les catégories</p>
				</a>
				<a href={`${base}association-handicap-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Associations handicap à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Accompagnement et soutien</p>
				</a>
				<a href={`${base}entraide-incontinence-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Association incontinence à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Entraide et accompagnement</p>
				</a>
				<a href={`${base}association-aidants-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Soutien aux aidants familiaux</p>
					<p class="text-xs text-gray-500 mt-1">Répit, groupes de parole</p>
				</a>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-16 bg-teal-50">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-2xl font-bold text-gray-900 mb-4">Besoin d'orientation ?</h2>
			<p class="text-gray-600 mb-8">Var Incontinence vous aide à trouver l'association santé adaptée à votre situation à Toulon et dans le Var.</p>
			<a href={`${base}#contact`} class="inline-block bg-teal-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-teal-700 transition-colors">Contactez-nous</a>
		</div>
	</section>

</Layout>
