---
import Layout from '../layouts/Layout.astro';
import { associations } from '../data/associations';
import { toSlug } from '../data/utils';

const base = import.meta.env.BASE_URL;
const handicapAssos = associations.filter(a => a.categorie === 'Handicap');
---

<Layout title="Associations Handicap à Toulon (83) — Aide et Accompagnement | Var Incontinence">

	<meta slot="head" name="description" content="Découvrez les associations d'aide aux personnes handicapées à Toulon. Handicap moteur, sensoriel, mental : accompagnement, droits et orientation." />

	<script slot="head" type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "ItemList",
		"name": "Associations handicap à Toulon",
		"description": "Liste des associations d'aide aux personnes handicapées à Toulon (83)",
		"numberOfItems": handicapAssos.length,
		"itemListElement": handicapAssos.map((a, i) => ({
			"@type": "ListItem",
			"position": i + 1,
			"item": {
				"@type": "Organization",
				"name": a.nom,
				"description": a.description,
				"address": { "@type": "PostalAddress", "streetAddress": a.adresse, "addressLocality": "Toulon", "postalCode": "83000" },
				...(a.telephone ? { "telephone": a.telephone } : {})
			}
		}))
	})} />

	<!-- Hero -->
	<section class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white py-16 md:py-20">
		<div class="max-w-6xl mx-auto px-4">
			<nav class="text-teal-200 text-sm mb-6" aria-label="Fil d'Ariane">
				<a href={base} class="hover:text-white transition-colors">Accueil</a>
				<span class="mx-2">/</span>
				<a href={`${base}toulon-association/`} class="hover:text-white transition-colors">Associations à Toulon</a>
				<span class="mx-2">/</span>
				<span class="text-white">Handicap</span>
			</nav>
			<h1 class="text-3xl md:text-5xl font-bold mb-4">Associations handicap à Toulon : accompagnement et soutien</h1>
			<p class="text-lg text-teal-100 max-w-3xl">
				Guide complet des associations d'aide aux personnes en situation de handicap à Toulon et dans le Var (83). Handicap moteur, sensoriel, mental et psychique : accompagnement, droits et orientation.
			</p>
			<div class="mt-6 flex items-center gap-2 text-teal-200 text-sm">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
				<span>{handicapAssos.length} associations référencées</span>
			</div>
		</div>
	</section>

	<!-- Introduction SEO -->
	<section class="py-12 bg-gray-50 border-b border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Le handicap à Toulon : un accompagnement associatif essentiel</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					Dans le Var, on estime que plus de <strong>80 000 personnes sont en situation de handicap</strong>, dont une part significative réside à Toulon et dans son agglomération. Face à cette réalité, un réseau dense d'associations s'est constitué pour répondre aux besoins spécifiques de chaque type de handicap : moteur, sensoriel (visuel et auditif), mental, psychique et cognitif.
				</p>
				<p>
					Ces associations jouent un rôle crucial à plusieurs niveaux : <strong>accompagnement au quotidien</strong> (aide à domicile, transport adapté, activités), <strong>défense des droits</strong> (accès à l'emploi, accessibilité, scolarisation inclusive), <strong>soutien aux familles</strong> (groupes de parole, guidance parentale, répit pour les aidants) et <strong>insertion professionnelle</strong> (ESAT, formation, emploi accompagné).
				</p>
				<p>
					Que vous soyez directement concerné(e) par le handicap ou que vous accompagniez un proche, vous trouverez ci-dessous les associations actives à Toulon, classées par type de handicap. Pour une vue d'ensemble de toutes les associations, consultez notre <a href={`${base}toulon-association/`} class="text-teal-600 underline hover:text-teal-800">annuaire complet des associations à Toulon</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- Liste des associations handicap -->
	<section class="py-16 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-8">Les associations handicap à Toulon et dans le Var</h2>
			<div class="grid gap-5">
				{handicapAssos.map((a, i) => (
					<article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:border-teal-300 hover:shadow-md transition-all">
						<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-3">
									<span class="w-8 h-8 bg-blue-100 text-blue-700 rounded-lg flex items-center justify-center text-sm font-bold">{i + 1}</span>
									<h3 class="text-xl font-bold text-gray-900">{a.nom}</h3>
								</div>
								<p class="text-gray-600 mb-4">{a.description}</p>
								<div class="flex flex-wrap gap-2">
									{a.domaines.map(d => (
										<span class="bg-blue-50 text-blue-700 text-xs font-medium px-3 py-1 rounded-full">{d}</span>
									))}
								</div>
							</div>
							<div class="md:text-right shrink-0 space-y-2">
								<div class="flex items-center gap-2 text-sm text-gray-600">
									<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
									<span>{a.adresse}</span>
								</div>
								{a.telephone && (
									<div class="flex items-center gap-2 text-sm">
										<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
										<a href={`tel:${a.telephone.replace(/\s/g, '')}`} class="text-teal-600 font-medium hover:text-teal-800">{a.telephone}</a>
									</div>
								)}
								{a.siteWeb && (
									<div class="flex items-center gap-2 text-sm">
										<svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
										<a href={a.siteWeb} target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-800 truncate max-w-[200px]">{a.siteWeb.replace('https://', '').replace('www.', '')}</a>
									</div>
								)}
								<div class="mt-2">
									<a href={`${base}association/${toSlug(a.nom)}/`} class="inline-flex items-center gap-1 text-xs text-white bg-teal-600 hover:bg-teal-700 font-medium px-3 py-1.5 rounded-full transition-all">
										<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
										Voir la fiche
									</a>
								</div>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Section MDPH et droits -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Droits des personnes handicapées dans le Var</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<p>
					La <strong>Maison Départementale des Personnes Handicapées (MDPH) du Var</strong> est le guichet unique pour toutes les demandes liées au handicap : reconnaissance du handicap, carte mobilité inclusion (CMI), allocation aux adultes handicapés (AAH), prestation de compensation du handicap (PCH), orientation vers les établissements et services.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">MDPH du Var : informations pratiques</h3>
				<div class="bg-white rounded-xl p-5 border border-gray-200 mt-4">
					<p class="font-bold text-gray-900">MDPH 83 - Maison Départementale des Personnes Handicapées du Var</p>
					<p class="text-sm text-gray-600 mt-2">234 boulevard Maréchal Foch, 83000 Toulon</p>
					<p class="text-sm text-gray-600">Tél : 04 94 05 10 40</p>
					<p class="text-sm text-gray-600">Accueil sur rendez-vous</p>
				</div>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Les principales aides accessibles</h3>
				<ul class="list-disc pl-6 space-y-2">
					<li><strong>AAH (Allocation aux Adultes Handicapés)</strong> : jusqu'à 1 016 euros par mois pour les personnes ayant un taux d'incapacité d'au moins 80%.</li>
					<li><strong>PCH (Prestation de Compensation du Handicap)</strong> : financement d'aides humaines, techniques, aménagement du logement et du véhicule.</li>
					<li><strong>CMI (Carte Mobilité Inclusion)</strong> : mentions invalidité, priorité ou stationnement selon le niveau de handicap.</li>
					<li><strong>RQTH (Reconnaissance de la Qualité de Travailleur Handicapé)</strong> : facilite l'accès à l'emploi, à la formation et à des aménagements de poste.</li>
					<li><strong>Orientation ESAT / Milieu protégé</strong> : pour les personnes dont le handicap limite fortement les capacités de travail en milieu ordinaire.</li>
				</ul>
				<p class="mt-4">
					Les associations listées ci-dessus peuvent vous accompagner dans toutes ces démarches auprès de la MDPH du Var. Pour un guide complet sur les droits, consultez notre article <a href={`${base}blog/droits-handicap-toulon-var/`} class="text-teal-600 underline hover:text-teal-800">Handicap à Toulon : vos droits et les aides disponibles dans le Var</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- Handicap par type -->
	<section class="py-12 bg-white border-t border-gray-100">
		<div class="max-w-4xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Les différents types de handicap accompagnés à Toulon</h2>
			<div class="text-gray-600 leading-relaxed space-y-4">
				<h3 class="text-xl font-bold text-gray-900">Handicap moteur</h3>
				<p>
					Le handicap moteur concerne les atteintes de la motricité : paralysie, amputation, troubles musculo-squelettiques, maladies neurologiques. À Toulon, <strong>APF France Handicap</strong> est la principale association de référence, complétée par <strong>Handisport Var</strong> pour la pratique sportive adaptée et l'<strong>Association des Traumatisés Crâniens du Var</strong> pour les cérébro-lésés.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Handicap sensoriel</h3>
				<p>
					Le handicap visuel est accompagné par l'<strong>Association Valentin Haüy</strong> (transcription braille, bibliothèque sonore, informatique adaptée). Pour le handicap auditif, l'<strong>URAPEDA PACA</strong> propose interprétation en langue des signes, aide aux démarches et soutien à la scolarisation des enfants sourds.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Handicap mental et psychique</h3>
				<p>
					L'<strong>ADAPEI Var Méditerranée</strong> accompagne les personnes handicapées mentales de la petite enfance à l'âge adulte (IME, ESAT, foyers). L'<strong>UNAFAM Var</strong> soutient les familles de malades psychiques avec des groupes de parole et des permanences d'écoute. Pour l'autisme, <strong>Autisme PACA</strong> propose guidance parentale et groupes d'habiletés sociales.
				</p>
				<h3 class="text-xl font-bold text-gray-900 pt-4">Handicap et incontinence</h3>
				<p>
					L'incontinence est fréquemment associée à certains handicaps (lésions médullaires, sclérose en plaques, AVC). Notre association <strong>Var Incontinence</strong> propose un accompagnement spécifique pour les personnes handicapées souffrant de troubles urinaires. Consultez notre page d'<a href={`${base}entraide-incontinence-toulon/`} class="text-teal-600 underline hover:text-teal-800">entraide incontinence à Toulon</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- Maillage interne -->
	<section class="py-12 bg-gray-50 border-t border-gray-100">
		<div class="max-w-6xl mx-auto px-4">
			<h2 class="text-xl font-bold text-gray-900 mb-4">Pages associées</h2>
			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
				<a href={`${base}toulon-association/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Annuaire complet des associations à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Toutes les catégories</p>
				</a>
				<a href={`${base}association-seniors-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Associations seniors à Toulon</p>
					<p class="text-xs text-gray-500 mt-1">Autonomie et lien social</p>
				</a>
				<a href={`${base}association-aidants-toulon/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Soutien aux aidants familiaux</p>
					<p class="text-xs text-gray-500 mt-1">Répit, groupes de parole</p>
				</a>
				<a href={`${base}blog/droits-handicap-toulon-var/`} class="bg-white rounded-xl p-5 hover:bg-teal-50 hover:border-teal-300 border border-gray-200 transition-all group">
					<p class="font-semibold text-gray-900 group-hover:text-teal-700">Vos droits handicap dans le Var</p>
					<p class="text-xs text-gray-500 mt-1">MDPH, AAH, PCH, CMI</p>
				</a>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-16 bg-teal-50">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-2xl font-bold text-gray-900 mb-4">Besoin d'orientation ?</h2>
			<p class="text-gray-600 mb-8">Var Incontinence vous aide à trouver l'association adaptée à votre situation de handicap à Toulon.</p>
			<a href={`${base}#contact`} class="inline-block bg-teal-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-teal-700 transition-colors">Contactez-nous</a>
		</div>
	</section>

</Layout>
